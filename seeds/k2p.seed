CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_phicomm_k2p=y

# 核心：只留 Passwall + Xray
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Xray=y
# 彻底关掉所有其他代理核心和不必要的辅助工具
# CONFIG_PACKAGE_ipt2socks is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_SingBox is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_V2ray is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Trojan_Plus is not set

# 彻底剔除语言包（先用英文版测试体积，成功了再考虑加中文）
# CONFIG_PACKAGE_luci-i18n-passwall-zh-cn is not set

# 彻底剔除所有“非生活必需品”
# CONFIG_PACKAGE_kmod-zram is not set
# CONFIG_PACKAGE_zram-swap is not set
# CONFIG_PACKAGE_odhcp6c is not set
# CONFIG_PACKAGE_odhcpd-ipv6only is not set
# CONFIG_PACKAGE_kmod-iptunnel is not set
# CONFIG_PACKAGE_kmod-iptunnel4 is not set
# CONFIG_PACKAGE_kmod-udptunnel4 is not set

# 强制开启极致压缩选项
CONFIG_STRIP_KERNEL_EXPORTS=y
CONFIG_USE_MKLIBS=y
CONFIG_CLEAN_IPKG=y
